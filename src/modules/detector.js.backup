// detector.js
// Updated for Human.js 3.3.6 - AI detection pipeline
// Changes from v2.x: backend name, model paths, simplified instantiation

// IMPORTANT: Human 3.x uses 'webgl' not 'humangl', and imports differently
import Human from "@vladmandic/human";

const nsfwUrl = chrome.runtime.getURL("src/assets/models/nsfwjs/model.json");

// ============================================================================
// HUMAN CONFIG — Updated for v3.3.6
// ============================================================================
const HUMAN_CONFIG = {
    // Backend: 'webgl' is the standard name now (was 'humangl')
    // 'webgpu' is even faster on modern browsers but less compatible
    backend: "webgl",

    // Model base path — same CDN, but models may have updated versions
    modelBasePath: "https://cdn.jsdelivr.net/npm/@vladmandic/human/models/",

    // Caching is now dynamic in v3.x — no need for manual cacheSensitivity
    // But we keep it for compatibility with older behavior
    cacheSensitivity: 0.9,

    // Skip warmup — we'll do it manually after load
    warmup: "none",

    // Process asynchronously for better performance
    async: true,

    // Filter: disabled by default (we handle resizing ourselves)
    filter: {
        enabled: false,
    },

    // Face detection configuration
    face: {
        enabled: true,

        // Iris detection: disabled (not needed for gender classification)
        iris: { enabled: false },

        // Face mesh: disabled (not needed, saves performance)
        mesh: { enabled: false },

        // Detector: blazeface-back has better accuracy than blazeface
        // blazeface.json = lighter, faster
        // blazeface-back.json = more accurate, slightly slower
        detector: {
            modelPath: "blazeface-back.json",  // UPGRADED from "blazeface.json"
            maxDetected: 2,      // Max faces to detect per image
            minConfidence: 0.25,  // Minimum confidence to consider a face
        },

        // Description: gender, age, emotion
        description: {
            enabled: true,
            modelPath: "faceres.json",  // Same model, but updated weights in v3
        },

        // Emotion: disabled (not needed for our use case)
        emotion: { enabled: false },
    },

    // Disable everything else we don't need (saves memory & speed)
    body: { enabled: false },
    hand: { enabled: false },
    gesture: { enabled: false },
    object: { enabled: false },
};

// ============================================================================
// NSFW CONFIG — Same as before, works fine
// ============================================================================
const NSFW_CONFIG = {
    size: 224,          // Input size for NSFW model
    tfScalar: 255,      // Normalize pixel values
    topK: 3,            // Return top 3 predictions
    skipTime: 4000,     // Skip frames within 4 seconds
    skipFrames: 99,     // Skip up to 99 similar frames
    cacheSensitivity: 0.9,
};

// ============================================================================
// NSFW CLASS THRESHOLDS — Same logic, may need tuning
// ============================================================================
const getNsfwClasses = (factor = 0) => {
    // factor: 0 = strict, 1 = lenient
    return {
        0: { className: "Drawing", nsfw: false, thresh: 0.5 },
        1: { className: "Hentai",  nsfw: true,  thresh: 0.5 + (1 - factor) * 0.5 },
        2: { className: "Neutral", nsfw: false, thresh: 0.5 + factor * 0.5 },
        3: { className: "Porn",    nsfw: true,  thresh: 0.1 + (1 - factor) * 0.4 },
        4: { className: "Sexy",    nsfw: true,  thresh: 0.1 + (1 - factor) * 0.4 },
    };
};

// ============================================================================
// DETECTOR CLASS — Updated for Human 3.x
// ============================================================================
class Detector {
    constructor() {
        this._human = null;
        this._nsfwModel = null;
        this.nsfwCache = {
            predictions: [],
            timestamp: 0,
            skippedFrames: 0,
            lastInputTensor: null,
        };
    }

    get human() {
        return this._human;
    }

    get nsfwModel() {
        return this._nsfwModel;
    }

    // ------------------------------------------------------------------------
    // INIT HUMAN — Simplified for v3.x
    // ------------------------------------------------------------------------
    initHuman = async () => {
        // Human 3.x: new Human(config) instead of new Human.Human(config)
        this._human = new Human(HUMAN_CONFIG);

        // Load models
        await this._human.load();

        // Enable production mode for better performance
        this._human.tf.enableProdMode();

        // Warmup: create a dummy tensor and run detection
        // This pre-compiles shaders and avoids first-run lag
        const tensor = this._human.tf.zeros([1, 224, 224, 3]);
        await this._human.detect(tensor);
        this._human.tf.dispose(tensor);

        console.log("HB== Human model warmed up (v" + this._human.version + ")");
    };

    // ------------------------------------------------------------------------
    // HUMAN CLASSIFY — Face detection + gender/age
    // ------------------------------------------------------------------------
    humanModelClassify = async (tensor, needToResize) => {
        if (!this._human) await this.initHuman();

        // Human 3.x detect() returns a Result object with structured data
        // The API is the same, but internal processing is improved
        const promise = needToResize
            ? this._human.detect(tensor, {
                filter: {
                    enabled: true,
                    width: needToResize?.newWidth,
                    height: needToResize?.newHeight,
                },
            })
            : this._human.detect(tensor);

        return promise;
    };

    // ------------------------------------------------------------------------
    // INIT NSFW MODEL — Same logic, works with TFJS 4.x
    // ------------------------------------------------------------------------
    initNsfwModel = async () => {
        // Try to load from IndexedDB first (cached from previous session)
        const indexedDBModel =
            typeof indexedDB !== "undefined" &&
            (await this._human.tf.io.listModels());

        if (indexedDBModel?.["indexeddb://nsfw-model"]) {
            this._nsfwModel = await this._human.tf.loadGraphModel(
                "indexeddb://nsfw-model"
            );
            console.log("HB== NSFW model loaded from IndexedDB cache");
        } else {
            // Load from bundled model file
            this._nsfwModel = await this._human.tf.loadGraphModel(nsfwUrl);
            // Save to IndexedDB for next time
            await this._nsfwModel.save("indexeddb://nsfw-model");
            console.log("HB== NSFW model loaded from bundle and cached");
        }

        // Warmup
        const tensor = this._human.tf.zeros([1, 224, 224, 3]);
        await this._nsfwModel.predict(tensor);
        this._human.tf.dispose(tensor);
        console.log("HB== NSFW model warmed up");
    };

    // ------------------------------------------------------------------------
    // NSFW FRAME SKIP — Same logic, TFJS 4.x compatible
    // ------------------------------------------------------------------------
    nsfwModelSkip = async (input, config) => {
        const tf = this._human.tf;
        let skipFrame = false;

        if (
            config.cacheSensitivity === 0 ||
            !input?.shape ||
            input?.shape.length !== 4 ||
            input?.shape[1] > 3840 ||
            input?.shape[2] > 2160
        )
            return skipFrame;

        if (!this.nsfwCache.lastInputTensor) {
            this.nsfwCache.lastInputTensor = tf.clone(input);
        } else if (
            this.nsfwCache.lastInputTensor.shape[1] !== input.shape[1] ||
            this.nsfwCache.lastInputTensor.shape[2] !== input.shape[2]
        ) {
            tf.dispose(this.nsfwCache.lastInputTensor);
            this.nsfwCache.lastInputTensor = tf.clone(input);
        } else {
            const t = {};
            t.diff = tf.sub(input, this.nsfwCache.lastInputTensor);
            t.squared = tf.mul(t.diff, t.diff);
            t.sum = tf.sum(t.squared);
            const diffSum = await t.sum.data();
            const diffRelative =
                diffSum[0] /
                (input.shape[1] || 1) /
                (input.shape[2] || 1) /
                255 /
                3;
            tf.dispose([
                this.nsfwCache.lastInputTensor,
                t.diff,
                t.squared,
                t.sum,
            ]);
            this.nsfwCache.lastInputTensor = tf.clone(input);
            skipFrame = diffRelative <= (config.cacheSensitivity || 0);
        }
        return skipFrame;
    };

    // ------------------------------------------------------------------------
    // NSFW CLASSIFY — Same logic, TFJS 4.x compatible
    // ------------------------------------------------------------------------
    nsfwModelClassify = async (tensor, config = NSFW_CONFIG) => {
        if (!this._human) await this.initHuman();
        if (!this._nsfwModel) await this.initNsfwModel();

        const tf = this._human.tf;
        if (!tensor) return [];

        let resized, expanded;

        try {
            const skipAllowed = await this.nsfwModelSkip(tensor, config);
            const skipFrame =
                this.nsfwCache.skippedFrames < (config.skipFrames || 0);
            const skipTime =
                (config.skipTime || 0) >
                (performance?.now?.() || Date.now()) - this.nsfwCache.timestamp;

            if (
                !skipAllowed ||
                !skipTime ||
                !skipFrame ||
                this.nsfwCache.predictions.length === 0
            ) {
                // Resize if needed
                if (
                    tensor.shape[1] !== config.size ||
                    tensor.shape[2] !== config.size
                ) {
                    resized = tf.image.resizeNearestNeighbor(tensor, [
                        config.size,
                        config.size,
                    ]);
                }
                // Expand dimensions if 3D
                if (
                    (resized && resized.shape.length === 3) ||
                    tensor.shape.length === 3
                ) {
                    expanded = tf.expandDims(resized || tensor, 0);
                }

                const scalar = tf.scalar(config.tfScalar);
                const normalized = tf.div(
                    expanded || resized || tensor,
                    scalar
                );
                const logits = await this._nsfwModel.predict(normalized);

                this.nsfwCache.predictions = await this.getTopKClasses(
                    logits,
                    config.topK
                );
                this.nsfwCache.timestamp = performance?.now?.() || Date.now();
                this.nsfwCache.skippedFrames = 0;

                tf.dispose(
                    [scalar, normalized, logits]
                    .concat(expanded ? [expanded] : [])
                    .concat(resized ? [resized] : [])
                );
            } else {
                this.nsfwCache.skippedFrames++;
            }

            return this.nsfwCache.predictions;
        } catch (error) {
            console.error("HB== NSFW Detection Error", resized || tensor, error);
            return [];
        }
    };

    // ------------------------------------------------------------------------
    // GET TOP K CLASSES — Same logic
    // ------------------------------------------------------------------------
    getTopKClasses = async (logits, topK) => {
        const values = await logits.data();
        const valuesAndIndices = [];

        for (let i = 0; i < values.length; i++) {
            valuesAndIndices.push({ value: values[i], index: i });
        }

        valuesAndIndices.sort((a, b) => b.value - a.value);

        const topkValues = new Float32Array(topK);
        const topkIndices = new Int32Array(topK);

        for (let i = 0; i < topK; i++) {
            topkValues[i] = valuesAndIndices[i].value;
            topkIndices[i] = valuesAndIndices[i].index;
        }

        const topClassesAndProbs = [];
        for (let i = 0; i < topkIndices.length; i++) {
            topClassesAndProbs.push({
                className: getNsfwClasses()?.[topkIndices[i]]?.className,
                probability: topkValues[i],
                id: topkIndices[i],
            });
        }
        return topClassesAndProbs;
    };
}

// ============================================================================
// NSFW DETECTION HELPER — Same logic
// ============================================================================
const containsNsfw = (nsfwDetections, strictness) => {
    if (!nsfwDetections?.length) return false;
    let highestNsfwDelta = 0;
    let highestSfwDelta = 0;

    const nsfwClasses = getNsfwClasses(strictness);
    nsfwDetections.forEach((det) => {
        if (nsfwClasses?.[det.id]?.nsfw) {
            highestNsfwDelta = Math.max(
                highestNsfwDelta,
                det.probability - nsfwClasses[det.id].thresh
            );
        } else {
            highestSfwDelta = Math.max(
                highestSfwDelta,
                det.probability - nsfwClasses[det.id].thresh
            );
        }
    });
    return highestNsfwDelta > highestSfwDelta;
};

// ============================================================================
// GENDER DETECTION HELPER — May need threshold tuning with new model
// ============================================================================
const genderPredicate = (gender, score, detectMale, detectFemale) => {
    // NOTE: With Human 3.x faceres model, gender scores may be more accurate
    // but the threshold ranges might be different. 
    // Start with same thresholds, test and adjust.

    const mPredicate =
        (gender === "male" && score > 0.3) ||
        (gender === "female" && score < 0.2);

    const fePredicate = gender === "female" && score > 0.25;

    if (detectMale && detectFemale) return mPredicate || fePredicate;
    if (detectMale && !detectFemale) return mPredicate;
    if (!detectMale && detectFemale) return fePredicate;

    return false;
};

const containsGenderFace = (detections, detectMale, detectFemale) => {
    if (!detections?.face?.length) {
        return false;
    }

    const faces = detections.face;
    if (detectMale || detectFemale)
        return faces.some(
            (face) =>
                face.age > 20 &&
                genderPredicate(
                    face.gender,
                    face.genderScore,
                    detectMale,
                    detectFemale
                )
        );
    else return false;
};

export { getNsfwClasses, containsNsfw, containsGenderFace, Detector };